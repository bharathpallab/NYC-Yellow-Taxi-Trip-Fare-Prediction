      "source": [
        "# 09_Model_Comparison_and_Evaluation\n",
        "\n",
        "**Project:** Taxi Fare Amount Prediction Using NYC Yellow Taxi Big Data\n",
        "\n",
        "This notebook loads all persisted models, generates predictions on the hold‑out test set, computes a suite of regression metrics (RMSE, MAE, R², MAPE), and visualises a comparative performance chart.\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "%run ./04_Feature_Engineering.ipynb\n",
        "\n",
        "from pyspark.ml.regression import LinearRegressionModel, DecisionTreeRegressionModel, RandomForestRegressionModel, GBTRegressionModel\n",
        "from pyspark.ml.evaluation import RegressionEvaluator\n",
        "import os, pandas as pd, matplotlib.pyplot as plt, seaborn as sns\n",
        "\n",
        "# Re‑create the same train‑test split used during training\n",
        "train_df, test_df = df_feat.randomSplit([0.8, 0.2], seed=42)\n",
        "\n",
        "model_dir = r'C:\\Users\\shiva\\OneDrive\\Desktop\\mtechbigdata2\\nyctaxidata\\models'\n",
        "model_paths = {\n",
        "    'LinearRegression': os.path.join(model_dir, 'linear_regression'),\n        "    'DecisionTree': os.path.join(model_dir, 'decision_tree'),\n        "    'RandomForest': os.path.join(model_dir, 'random_forest'),\n        "    'GradientBoostedTrees': os.path.join(model_dir, 'gradient_boosted_trees')\n",
        "}\n",
        "\n",
        "evaluator_rmse = RegressionEvaluator(labelCol='fare_amount', predictionCol='prediction', metricName='rmse')\n",
        "evaluator_mae  = RegressionEvaluator(labelCol='fare_amount', predictionCol='prediction', metricName='mae')\n",
        "evaluator_r2   = RegressionEvaluator(labelCol='fare_amount', predictionCol='prediction', metricName='r2')\n",
        "\n",
        "results = []\n",
        "for name, path in model_paths.items():\n",
        "    print(f'Loading {name} model from {path}')\n",
        "    if name == 'LinearRegression':\n",
        "        model = LinearRegressionModel.load(path)\n",
        "    elif name == 'DecisionTree':\n",
        "        model = DecisionTreeRegressionModel.load(path)\n",
        "    elif name == 'RandomForest':\n",
        "        model = RandomForestRegressionModel.load(path)\n",
        "    elif name == 'GradientBoostedTrees':\n",
        "        model = GBTRegressionModel.load(path)\n",
        "    else:\n",
        "        continue\n",
        "    preds = model.transform(test_df)\n",
        "    rmse = evaluator_rmse.evaluate(preds)\n",
        "    mae  = evaluator_mae.evaluate(preds)\n",
        "    r2   = evaluator_r2.evaluate(preds)\n",
        "    # Mean Absolute Percentage Error (custom)\n",
        "    mae_df = preds.select('fare_amount', 'prediction')\n",
        "    mape = mae_df.rdd.map(lambda row: abs((row['fare_amount'] - row['prediction']) / row['fare_amount']))\n",
        "    mape = mape.mean() * 100\n",
        "    results.append({\n",
        "        'Model': name,\n",
        "        'RMSE': rmse,\n",
        "        'MAE': mae,\n",
        "        'R2': r2,\n",
        "        'MAPE_%': mape\n",
        "    })\n",
        "    print(f'{name} – RMSE: {rmse:.4f}, MAE: {mae:.4f}, R2: {r2:.4f}, MAPE: {mape:.2f}%')\n",
        "\n",
        "# Convert to Pandas for visualisation\n",
        "perf_df = pd.DataFrame(results).set_index('Model')\",
        "\n",
        "sns.set(style='whitegrid')\n",
        "plt.figure(figsize=(10,6))\n",
        "perf_df[['RMSE','MAE']].plot(kind='bar')\n",
        "plt.title('Regression Error Metrics by Model')\n",
        "plt.ylabel('Error')\n",
        "plt.xticks(rotation=0)\n",
        "plt.show()\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "sns.barplot(x=perf_df.index, y='R2', data=perf_df.reset_index())\n",
        "plt.title('R² Score Comparison')\n",
        "plt.ylabel('R²')\n",
        "plt.show()"
      ]
    }
  ],
