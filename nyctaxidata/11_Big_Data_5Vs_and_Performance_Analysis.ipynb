      "source": [
        "# 11_Big_Data_5Vs_and_Performance_Analysis\n",
        "\n",
        "**Project:** Taxi Fare Amount Prediction Using NYC Yellow Taxi Big Data\n",
        "\n",
        "This notebook discusses the five *V* characteristics of the dataset (Volume, Velocity, Variety, Veracity, Value) and provides a brief Spark performance analysis using Spark UI metrics. The notebook also includes a mock‑up of the Spark UI dashboard for inclusion in the final report.\n",
        "\n",
        "![Spark UI Dashboard](file:///C:/Users/shiva/.gemini/antigravity-ide/brain/1c7e0cde-5855-4ac2-9461-8c9e4602cd94/spark_ui_placeholder_1782228914659.png)\n"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {},
      "outputs": [],
      "source": [
        "%run ./01_Data_Loading_and_Spark_Setup.ipynb\n",
        "\n",
        "from pyspark.sql import functions as F\n",
        "import time, os\n",
        "\n",
        "# ---- Volume ----\n",
        "row_count = df.count()\n",
        "print(f'Rows (Volume): {row_count:,}')\n",
        "\n",
        "# Approximate data size on storage (in GB)\n",
        "# Spark does not expose file size directly; we approximate using Hadoop FS if available\n",
        "try:\n",
        "    fs = spark._jvm.org.apache.hadoop.fs.FileSystem.get(spark._jsc.hadoopConfiguration())\n",
        "    path = spark._jvm.org.apache.hadoop.fs.Path(data_dir)\n",
        "    size_bytes = fs.getContentSummary(path).getLength()\n",
        "    size_gb = size_bytes / (1024**3)\n",
        "    print(f'Dataset size on disk: {size_gb:.2f} GB')\n",
        "except Exception as e:\n",
        "    print('Could not determine size via Hadoop FS:', e)\n",
        "\n",
        "# ---- Velocity ----\n",
        "# Measure load time (already captured) and a simple transformation time\n",
        "start = time.time()\n",
        "df_sample = df.limit(100000).cache()  # simple operation on a subset\n",
        "df_sample.count()\n",
        "print(f'Velocity test (100k rows cache) took {time.time() - start:.2f}s')\n",
        "\n",
        "# ---- Variety ----\n",
        "print('Columns (Variety):')\n",
        "for field in df.schema.fields:\n",
        "    print(f' - {field.name}: {field.dataType}')\n",
        "\n",
        "# ---- Veracity ----\n",
        "# Simple data quality metrics (nulls, duplicates)\n",
        "null_counts = df.select([F.count(F.when(F.col(c).isNull(), c)).alias(c) for c in df.columns])\n",
        "null_counts.show(truncate=False)\n",
        "dup_count = df.groupBy(df.columns).count().filter('count > 1').count()\n",
        "print(f'Duplicate records: {dup_count}')\n",
        "\n",
        "# ---- Value ----\n",
        "# Compute basic business KPI: average fare per mile\n",
        "kpi = df.filter(F.col('trip_distance') > 0).agg(\n",
        "    (F.sum('fare_amount') / F.sum('trip_distance')).alias('avg_fare_per_mile')\n",
        ").collect()[0]['avg_fare_per_mile']\n",
        "print(f'Average fare per mile (Value): ${kpi:.2f}')\n",
        "\n",
        "# ---- Spark Performance Metrics ----\n",
        "# Retrieve job metrics from Spark UI (available via SparkListener)\n",
        "spark_context = spark.sparkContext\n",
        "status_tracker = spark_context.statusTracker()\n",
        "jobs = status_tracker.getJobIds()\n",
        "print(f'Number of Spark jobs executed in this session: {len(jobs)}')\n",
        "# Example: Show stage metrics for the most recent job\n",
        "if jobs:\n",
        "    last_job = jobs[-1]\n",
        "    job_info = status_tracker.getJobInfo(last_job)\n",
        "    stage_ids = job_info.stageIds\n",
        "    for sid in stage_ids:\n",
        "        stage_info = status_tracker.getStageInfo(sid)\n",
        "        print(f'Stage {sid}:')\n",
        "        print(f'  Tasks: {stage_info.numTasks}, Duration: {stage_info.duration} ms')\n",
        "        print(f'  Shuffle Read: {stage_info.shuffleReadMetrics.remoteBytesRead if stage_info.shuffleReadMetrics else "N/A"} bytes')\n",
        "        print(f'  Shuffle Write: {stage_info.shuffleWriteMetrics.bytesWritten if stage_info.shuffleWriteMetrics else "N/A"} bytes')\n",
        "\n",
        "# Summarise the 5Vs and performance insights\n",
        "print('\n--- Summary of 5Vs and Performance ---')\n",
        "print(f'Volume: {row_count:,} rows, approx. {size_gb:.2f} GB')\n",
        "print(f'Velocity: load time captured earlier, transformation test 100k rows took {time.time() - start:.2f}s')\n",
        "print(f'Variety: {len(df.columns)} columns with mixed types')\n",
        "print(f'Veracity: {null_counts.select([F.sum(c) for c in null_counts.columns]).collect()[0][0]} nulls, {dup_count} duplicates')\n",
        "print(f'Value: Avg fare per mile ${kpi:.2f}')\n"
      ]
    }
  ],
